<% layout("layouts/boilerplate") %>
<%
const existingImages = (decoration.images && decoration.images.length)
    ? decoration.images
    : (decoration.image ? [decoration.image] : []);
%>

<h1 class="mb-4">Edit Decoration</h1>

<form action="/decorations/<%= decoration._id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="card p-4 shadow-sm">
    <div class="mb-3">
        <label for="title" class="form-label">Decoration Title</label>
        <input id="title" type="text" name="title" value="<%= decoration.title %>" class="form-control" required>
    </div>

    <div class="mb-3">
        <label for="price" class="form-label">Price</label>
        <input id="price" type="number" name="price" value="<%= decoration.price %>" class="form-control" required>
    </div>

    <% if (existingImages.length) { %>
        <div class="mb-3">
            <label class="form-label">Current Images</label>
            <div class="row g-3">
                <% existingImages.forEach(function(img, index) { %>
                    <div class="col-sm-6 col-md-4">
                        <img src="<%= img %>" alt="Decoration image <%= index + 1 %>" class="gallery-img">
                    </div>
                <% }) %>
            </div>
        </div>
    <% } %>

    <div class="mb-3">
        <label for="images" class="form-label">Upload New Images</label>
        <input id="images" type="file" name="images" multiple class="form-control" accept="image/*">
        <div class="form-text">Uploading new images will replace the current image gallery.</div>
    </div>

    <div class="mb-3">
        <label for="video" class="form-label">Replace Video</label>
        <input id="video" type="file" name="video" class="form-control" accept="video/*">
    </div>

    <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea id="description" name="description" class="form-control" rows="4"><%= decoration.description %></textarea>
    </div>

    <button class="btn btn-primary">Update Decoration</button>
</form>
