<% layout("layouts/boilerplate") %>

<h1 class="mb-4 text-center">Explore Decorations</h1>
<p class="text-center text-muted mb-5">
Find beautiful decorations for weddings, birthdays, and events.
</p>

<% if(admin){ %>

<a href="/decorations/new" class="btn btn-primary mb-4">
Add Decoration
</a>

<% } %>

<div class="row">

<% if(decorations.length === 0){ %>

<div class="col-12">

<div class="alert alert-info text-center">
No decorations available yet. Please add a decoration.
</div>

</div>

<% } else { %>

<% for(let decoration of decorations){ %>

<div class="col-lg-4 col-md-6 mb-4">

<div class="card shadow-sm">

<img src="<%= decoration.image %>" class="card-img-top">

<div class="card-body">

<h5 class="card-title">

<a href="/decorations/<%= decoration._id %>" class="text-decoration-none text-dark">
<%= decoration.title %>
</a>

</h5>

<p class="card-text text-muted">
₹ <%= decoration.price %>
</p>

</div>

</div>

</div>

<% } %>

<% } %>

</div>