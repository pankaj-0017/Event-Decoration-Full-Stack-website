<!DOCTYPE html>
<html>
<head>
<title>Decoration Website</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

</head>
<body class="container mt-4">
<% layout("layouts/boilerplate") %>
<h1 class="mb-4">All Decorations</h1>

<% if(admin){ %>

<a href="/decorations/new" class="btn btn-primary mb-4">
Add Decoration
</a>

<% } %>

<div class="row">

<% if(decorations.length === 0){ %>

<div class="col-12">

<div class="alert alert-info text-center">

No decorations available yet. Please add a decoration.

</div>

</div>

<% } else { %>

<% for(let decoration of decorations){ %>

<div class="col-md-4 mb-4">

<div class="card shadow-sm">

<img src="<%= decoration.image %>" class="card-img-top" style="height:250px; object-fit:cover;">

<div class="card-body">

<h5 class="card-title">

<a href="/decorations/<%= decoration._id %>" class="text-decoration-none text-dark">

<%= decoration.title %>

</a>

</h5>

<p class="card-text text-muted">

₹ <%= decoration.price %>

</p>

</div>

</div>

</div>

<% } %>

<% } %>

</div>
</body>
</html>