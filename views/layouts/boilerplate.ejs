<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RadheShyam Decorator</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="/css/style.css?v=2">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css">
</head>

<body>
<div class="site-shell">
    <header class="site-header">
        <div class="container">
            <nav class="site-navbar">
                <a class="site-logo" href="/">
                    <span class="site-logo-mark">R</span>
                    <span>RadheShyam Decorator</span>
                </a>

                <div class="site-nav-panel">
                    <ul class="site-nav-links">
                        <li><a href="/">Home</a></li>
                        <li><a href="/decorations">Decorations</a></li>
                        <% if(admin){ %>
                            <li><a href="/decorations/new">Add Decoration</a></li>
                            <li><a href="/admin/logout">Logout</a></li>
                        <% } else { %>
                            <li><a href="/admin/login">Login</a></li>
                        <% } %>
                    </ul>
                </div>
            </nav>
        </div>
    </header>

    <main class="site-main">
        <div class="container site-main-container mt-4">
            <% if(success && success.length > 0){ %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <%= success[0] %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

            <% if(error && error.length > 0){ %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%= error[0] %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

            <%- body %>
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-grid">
                <section class="footer-block">
                    <p class="footer-eyebrow">About</p>
                    <h5>RadheShyam Decorator</h5>
                    <p>
                        RadheShyam Decorator brings elegant decoration ideas for weddings,
                        birthdays, receptions, and event spaces with a polished visual presentation.
                    </p>
                </section>

                <section class="footer-block">
                    <p class="footer-eyebrow">Contact</p>
                    <p><strong>Email:</strong> radheshyamdecorator@gmail.com</p>
                    <p><strong>Phone:</strong> +91 9518537865</p>
                    <p><strong>Location:</strong> Nimgaon Wagha, Ahilyanagar</p>
                </section>

                <section class="footer-block">
                    <p class="footer-eyebrow">Social</p>
                    <div class="social-links">
                        <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" aria-label="Pinterest"><i class="bi bi-pinterest"></i></a>
                        <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                    </div>
                </section>
            </div>

            <div class="footer-bottom">
                <p>&copy; 2026 RadheShyam Decorator. All rights reserved.</p>
            </div>
        </div>
    </footer>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>

<script>
const lightbox = GLightbox({
selector: '.gallery-lightbox'
});
</script>
</body>
</html>
